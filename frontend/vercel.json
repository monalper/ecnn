{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "https://ecnn-backend.vercel.app/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "https://ecnn-backend.vercel.app/robots.txt"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/site.webmanifest",
      "dest": "/site.webmanifest"
    },
    {
      "src": "/reklam.png",
      "dest": "/reklam.png"
    },
    {
      "src": "/footerlogo.png",
      "dest": "/footerlogo.png"
    },
    {
      "src": "/footerlogo2.png",
      "dest": "/footerlogo2.png"
    },
    {
      "src": "/test-reklam.html",
      "dest": "/test-reklam.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
} 
